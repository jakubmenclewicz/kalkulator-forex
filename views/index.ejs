    <div class="container" style="margin-top: 50px; border-top: 1px solid var(--border); padding-top: 40px;">
    <div class="form-wrapper" style="max-width: 500px; margin: 0 auto; display: block;">
        <div class="form-section">
            <h3>❯❯ TRADE FLOW NEWSLETTER</h3>
            <form id="newsletterForm">
                <div class="form-group">
                    <label>NAME</label>
                    <input type="text" id="newsName" placeholder="Enter your name" required>
                </div>
                <div class="form-group">
                    <label>EMAIL</label>
                    <input type="email" id="newsEmail" placeholder="your@email.com" required>
                </div>
                <div class="form-group">
                    <label>COUNTRY</label>
                    <input type="text" id="newsCountry" placeholder="e.g. Poland" required>
                </div>
                <button type="submit" class="btn">◢ SUBSCRIBE NOW ◣</button>
            </form>
            <div id="statusMsg" style="margin-top: 15px; text-align: center; font-size: 12px; font-weight: bold;"></div>
        </div>
    </div>
</div>

<script>
    document.getElementById('newsletterForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const status = document.getElementById('statusMsg');
        const data = {
            name: document.getElementById('newsName').value,
            email: document.getElementById('newsEmail').value,
            country: document.getElementById('newsCountry').value
        };

        try {
            const response = await fetch('/subscribe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                status.style.color = "var(--primary)";
                status.textContent = "◢ SUCCESS: ADDED TO SUBSCRIBERS.TXT ◣";
                e.target.reset();
            } else {
                throw new Error();
            }
        } catch (err) {
            status.style.color = "#ff4757";
            status.textContent = "◢ ERROR: DATABASE CONNECTION FAILED ◣";
        }
    });
</script>

    <div class="footer">
        <p>◢ TRADE FLOW - Professional Trading Tools ◣</p>
