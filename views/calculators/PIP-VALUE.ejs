<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pip Value Calculator - Trade Flow</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .calc-container { margin-bottom: 50px; }
        .divider { border-top: 2px dashed rgba(255,255,255,0.1); margin: 40px 0; position: relative; }
        .divider span { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #1a1a1a; padding: 0 15px; color: #888; font-size: 12px; letter-spacing: 2px; }
    </style>
</head>
<body>
    <nav class="nav">
        <div class="nav-container">
            <a href="/" class="nav-logo">◢ TRADE FLOW ◣</a>
            <ul class="nav-links">
                <li><a href="/">MENU</a></li>
                <li><a href="/position-size">POSITION SIZE</a></li>
                <li><a href="/pip-value" class="active">PIP VALUE</a></li>
                <li><a href="/profit-loss">P/L</a></li>
                <li><a href="/risk-reward">RISK/REWARD</a></li>
            </ul>
        </div>
    </nav>

    <div class="header">
        <h1>◢ PIP VALUE CALCULATORS ◣</h1>
        <p>Understand the monetary value of every market move</p>
    </div>

    <div class="container">
        <div class="calc-container">
            <div class="form-wrapper">
                <div class="form-section">
                    <h3>❯❯ QUICK PIP VALUE</h3>
                    <form id="quickPipForm">
                        <div class="form-group">
                            <label>ACCOUNT CURRENCY</label>
                            <select id="qAccCurr">
                                <option value="USD">USD ($)</option>
                                <option value="EUR">EUR (€)</option>
                                <option value="PLN">PLN (zł)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>CURRENCY PAIR</label>
                            <select id="qPair">
                                <option value="10">EUR/USD, GBP/USD, AUD/USD</option>
                                <option value="6.73">USD/JPY (@ 148.50)</option>
                                <option value="7.42">USD/CAD (@ 1.34)</option>
                                <option value="11.25">GBP/JPY (@ 187.00)</option>
                                <option value="12.40">EUR/GBP (@ 0.85)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>TRADE SIZE (LOTS)</label>
                            <input type="number" id="qLots" value="1.0" step="0.01" required>
                        </div>
                        <button type="submit" class="btn">◢ CALCULATE VALUE ◣</button>
                    </form>
                </div>

                <div class="result-section" id="quickPipResults">
                    <div class="alert alert-success">
                        <h4>▸ VALUE PER 1 PIP:</h4>
                        <div style="font-size: 32px; font-weight: 900;" id="pipValDisplay">$ 10.00</div>
                    </div>
                    <div class="result-grid">
                        <div class="result-item">
                            <span class="result-label">POINT VALUE (1/10 PIP)</span>
                            <span class="result-value" id="pointValDisplay">$ 1.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"><span>OR</span></div>

        <div class="calc-container">
            <div class="form-wrapper">
                <div class="form-section">
                    <h3>❯❯ LOT SIZE COMPARISON</h3>
                    <p style="font-size: 13px; color: #888; margin-bottom: 20px;">Compare pip values across different contract sizes</p>
                    <form id="comparePipForm">
                        <div class="form-group">
                            <label>CUSTOM PIP VALUE (FOR 1 LOT)</label>
                            <input type="number" id="basePipVal" value="10" step="0.01" required>
                        </div>
                        <button type="submit" class="btn">◢ GENERATE COMPARISON ◣</button>
                    </form>
                </div>

                <div class="result-section" id="compareResults">
                    <table class="result-table">
                        <thead>
                            <tr>
                                <th>LOT TYPE</th>
                                <th>UNITS</th>
                                <th>PIP VALUE</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>STANDARD LOT</td>
                                <td>100,000</td>
                                <td id="valStd" style="color: var(--primary); font-weight: bold;">$ 10.00</td>
                            </tr>
                            <tr>
                                <td>MINI LOT (0.10)</td>
                                <td>10,000</td>
                                <td id="valMini">$ 1.00</td>
                            </tr>
                            <tr>
                                <td>MICRO LOT (0.01)</td>
                                <td>1,000</td>
                                <td id="valMicro">$ 0.10</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>◢ FOREX CALCULATORS - Professional Trading Tools ◣</p>
    </div>

    <script>
        // Kalkulator 1
        document.getElementById('quickPipForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const pairVal = parseFloat(document.getElementById('qPair').value);
            const lots = parseFloat(document.getElementById('qLots').value);
            const curr = document.getElementById('qAccCurr').value;
            const symbols = { 'USD': '$', 'EUR': '€', 'PLN': 'zł' };

            const totalPip = pairVal * lots;
            const totalPoint = totalPip / 10;

            document.getElementById('pipValDisplay').textContent = `${symbols[curr]} ${totalPip.toFixed(2)}`;
            document.getElementById('pointValDisplay').textContent = `${symbols[curr]} ${totalPoint.toFixed(2)}`;
            document.getElementById('quickPipResults').classList.add('show');
        });

        // Kalkulator 2
        document.getElementById('comparePipForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const base = parseFloat(document.getElementById('basePipVal').value);
            
            document.getElementById('valStd').textContent = `$ ${base.toFixed(2)}`;
            document.getElementById('valMini').textContent = `$ ${(base * 0.1).toFixed(2)}`;
            document.getElementById('valMicro').textContent = `$ ${(base * 0.01).toFixed(2)}`;
            
            document.getElementById('compareResults').classList.add('show');
        });
    </script>
</body>
</html>