<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Risk/Reward - TRADE FLOW</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="nav">
        <div class="nav-container">
            <a href="/" class="nav-logo">◢ TRADE FLOW ◣</a>
            <ul class="nav-links">
                <li><a href="/">MENU</a></li>
                <li><a href="/position-size">POS SIZE</a></li>
                <li><a href="/risk-reward" class="active">RISK/REWARD</a></li>
                <li><a href="/pivot-points">PIVOTS</a></li>
                <li><a href="/profit-loss">P/L</a></li>
            </ul>
        </div>
    </nav>

    <div class="header">
        <h1>◢ RISK / REWARD ANALYZER ◣</h1>
        <p>Mathematical edge and trade viability assessment</p>
    </div>

    <div class="container">
        <div class="form-wrapper">
            <div class="form-section">
                <h3>❯❯ TRADE PARAMETERS</h3>
                <form id="rrForm">
                    <div class="form-group">
                        <label>ENTRY PRICE</label>
                        <input type="number" id="entryPrice" step="0.00001" placeholder="1.08500" required>
                    </div>

                    <div class="form-group">
                        <label>STOP LOSS (EXIT AT LOSS)</label>
                        <input type="number" id="stopLoss" step="0.00001" placeholder="1.08000" required>
                    </div>

                    <div class="form-group">
                        <label>TAKE PROFIT (EXIT AT PROFIT)</label>
                        <input type="number" id="takeProfit" step="0.00001" placeholder="1.10000" required>
                    </div>

                    <button type="submit" class="btn">◢ ANALYZE VIABILITY ◣</button>
                    <button type="button" class="btn" style="background: var(--gray); color: var(--light); margin-top: 10px;" onclick="resetRR()">⟲ RESET SYSTEM</button>
                </form>
            </div>

            <div class="result-section" id="rrResults">
                <div class="alert">
                    <h4 id="resTitle">▸ ANALYSIS COMPLETE</h4>
                    <p style="font-size: 11px; opacity: 0.7;">Mathematical edge detected</p>
                </div>

                <div class="result-grid">
                    <div class="result-item" style="border-color: var(--primary);">
                        <span class="result-label">R:R RATIO</span>
                        <span class="result-value" id="rrRatio">1 : 0.0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">REQUIRED WIN RATE</span>
                        <span class="result-value" id="winRate" style="color: var(--light);">0%</span>
                    </div>
                </div>

                <div class="info-box" style="margin-top: 25px;">
                    <h4 style="color: var(--primary);">◢ VERDICT</h4>
                    <p id="rrVerdict" style="font-size: 13px; line-height: 1.4;">Enter trade parameters to calculate the risk-to-reward metrics.</p>
                </div>

                <table class="result-table" style="margin-top: 20px;">
                    <tr>
                        <td>Potential Profit (Pips/Pts)</td>
                        <td id="profitDist" style="color: var(--primary); text-align: right; font-weight: bold;">0</td>
                    </tr>
                    <tr>
                        <td>Potential Risk (Pips/Pts)</td>
                        <td id="riskDist" style="color: var(--accent); text-align: right; font-weight: bold;">0</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    

    <footer class="footer">
        <p>◢ TRADE FLOW - Professional Trading Tools ◣</p>
    </footer>

    <script>
        document.getElementById('rrForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const entry = parseFloat(document.getElementById('entryPrice').value);
            const sl = parseFloat(document.getElementById('stopLoss').value);
            const tp = parseFloat(document.getElementById('takeProfit').value);
            
            if (isNaN(entry) || isNaN(sl) || isNaN(tp)) return;

            const risk = Math.abs(entry - sl);
            const reward = Math.abs(tp - entry);
            const ratio = (reward / risk).toFixed(2);
            const breakevenWinRate = (1 / (1 + (reward / risk)) * 100).toFixed(1);

            // Update UI
            document.getElementById('rrRatio').textContent = `1 : ${ratio}`;
            document.getElementById('winRate').textContent = `${breakevenWinRate}%`;
            document.getElementById('profitDist').textContent = (reward * 100000 / 10).toFixed(1); // Approximate pips
            document.getElementById('riskDist').textContent = (risk * 100000 / 10).toFixed(1);

            const verdict = document.getElementById('rrVerdict');
            const ratioItem = document.getElementById('rrRatio').parentElement;

            if (ratio >= 2) {
                verdict.innerHTML = `<span style="color: var(--primary)">POSITIVE EDGE:</span> High probability setup. You can be wrong ${(100 - breakevenWinRate).toFixed(0)}% of the time and still be profitable.`;
                ratioItem.style.borderColor = "var(--primary)";
            } else if (ratio >= 1) {
                verdict.innerHTML = `<span style="color: #ffaa00">NEUTRAL EDGE:</span> Mediocre setup. Requires over ${breakevenWinRate}% accuracy to grow capital.`;
                ratioItem.style.borderColor = "#ffaa00";
            } else {
                verdict.innerHTML = `<span style="color: var(--accent)">NEGATIVE EDGE:</span> Suboptimal trade. Reward is smaller than risk. Avoid execution.`;
                ratioItem.style.borderColor = "var(--accent)";
            }

            document.getElementById('rrResults').classList.add('show');
        });

        function resetRR() {
            document.getElementById('rrForm').reset();
            document.getElementById('rrResults').classList.remove('show');
        }
    </script>
</body>
</html>