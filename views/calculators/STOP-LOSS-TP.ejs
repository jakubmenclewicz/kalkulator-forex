<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stop Loss / Take Profit Calculator - Trade Flow</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="nav">
        <div class="nav-container">
            <a href="/" class="nav-logo">◢ Trade Flow ◣</a>
            <ul class="nav-links">
                <li><a href="/">MENU</a></li>
                <li><a href="/position-size">POSITION SIZE</a></li>
                <li><a href="/stop-loss-take-profit" class="active">SL/TP</a></li>
                <li><a href="/profit-loss">P/L</a></li>
                <li><a href="/risk-reward">RISK/REWARD</a></li>
            </ul>
        </div>
    </nav>

    <div class="header">
        <h1>◢ STOP LOSS / TAKE PROFIT ◣</h1>
        <p>Precise SL & TP Levels for Your Trades</p>
    </div>

    <div class="container">
        <div class="info-box">
            <h4>❯❯ WHAT IS SL / TP?</h4>
            <p>
                <strong>Stop Loss (SL)</strong> is an order that automatically closes a position
                when price reaches a predefined loss level.
            </p>
            <p>
                <strong>Take Profit (TP)</strong> is an order that automatically closes a position
                when price reaches a predefined profit level.
            </p>
        </div>

        <div class="form-wrapper">
            <div class="form-section">
                <h3>❯❯ INPUT PARAMETERS</h3>
                
                <form id="slTpForm">
                    <div class="form-group">
                        <label>ENTRY PRICE</label>
                        <input type="number" name="entryPrice" value="1.1000" step="0.00001" required>
                    </div>

                    <div class="form-group">
                        <label>STOP LOSS (PIPS)</label>
                        <input type="number" name="stopLossPips" value="50" step="1" required>
                    </div>

                    <div class="form-group">
                        <label>TAKE PROFIT (PIPS)</label>
                        <input type="number" name="takeProfitPips" value="100" step="1" required>
                    </div>

                    <div class="form-group">
                        <label>TRADE DIRECTION</label>
                        <select name="direction">
                            <option value="buy">BUY (LONG)</option>
                            <option value="sell">SELL (SHORT)</option>
                        </select>
                    </div>

                    <button type="submit" class="btn">◢ CALCULATE SL / TP ◣</button>
                    <button type="button" class="btn btn-secondary" onclick="resetForm()">⟲ RESET</button>
                </form>
            </div>

            <div class="result-section" id="results">
                <h3>❯❯ CALCULATION RESULTS</h3>
                
                <div class="alert alert-success" id="slDisplay">
                    <h4>▸ STOP LOSS:</h4>
                    <div style="font-size: 28px; font-weight: bold; margin: 10px 0;" id="stopLoss">-</div>
                    <div id="slPips">-</div>
                </div>

                <div class="alert alert-success" id="tpDisplay">
                    <h4>▸ TAKE PROFIT:</h4>
                    <div style="font-size: 28px; font-weight: bold; margin: 10px 0;" id="takeProfit">-</div>
                    <div id="tpPips">-</div>
                </div>

                <div class="result-grid">
                    <div class="result-item">
                        <span class="result-label">RISK / REWARD RATIO</span>
                        <span class="result-value" id="rrRatio">-</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">BREAKEVEN</span>
                        <span class="result-value neutral" id="breakeven">-</span>
                    </div>
                </div>

                <div id="recommendation"></div>
            </div>
        </div>

        <div class="result-section show" style="margin-top: 40px;">
            <h3>❯❯ RISK / REWARD GUIDELINES</h3>
            <table class="result-table">
                <thead>
                    <tr>
                        <th>RATIO</th>
                        <th>MEANING</th>
                        <th>RECOMMENDATION</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>3:1 or higher</td>
                        <td>Excellent ratio</td>
                        <td style="color: var(--primary);">✓ VERY GOOD</td>
                    </tr>
                    <tr>
                        <td>2:1</td>
                        <td>Very good ratio</td>
                        <td style="color: var(--primary);">✓ GOOD</td>
                    </tr>
                    <tr>
                        <td>1.5:1</td>
                        <td>Acceptable ratio</td>
                        <td style="color: #ffc800;">⚠ AVERAGE</td>
                    </tr>
                    <tr>
                        <td>1:1 or lower</td>
                        <td>Poor ratio</td>
                        <td style="color: var(--accent);">✗ AVOID</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="footer">
        <p>◢ FOREX CALCULATORS - Professional Trading Tools ◣</p>
    </div>

<script>
    const form = document.getElementById('slTpForm');

    form.addEventListener('submit', (e) => {
        e.preventDefault();

        // 1. Pobranie danych z formularza
        const entry = parseFloat(form.entryPrice.value);
        const slPips = parseFloat(form.stopLossPips.value);
        const tpPips = parseFloat(form.takeProfitPips.value);
        const direction = form.direction.value;

        // 2. Określenie mnożnika pipsów
        // Jeśli cena ma mniej niż 3 miejsca po przecinku, zakładamy parę JPY (np. 148.50)
        // W przeciwnym razie pary standardowe (np. 1.1050)
        const isJpy = entry < 500 && entry.toString().split('.')[1]?.length <= 3;
        const pipValue = isJpy ? 0.01 : 0.0001;

        let slPrice, tpPrice;

        // 3. Obliczenia w zależności od kierunku
        if (direction === 'buy') {
            slPrice = entry - (slPips * pipValue);
            tpPrice = entry + (tpPips * pipValue);
        } else {
            // Dla SELL Stop Loss jest powyżej ceny, a Take Profit poniżej
            slPrice = entry + (slPips * pipValue);
            tpPrice = entry - (tpPips * pipValue);
        }

        // 4. Kalkulacja Risk/Reward Ratio
        const rr = (tpPips / slPips).toFixed(2);

        // 5. Przygotowanie wyników
        const precision = isJpy ? 3 : 5;
        const result = {
            stopLoss: slPrice.toFixed(precision),
            takeProfit: tpPrice.toFixed(precision),
            stopLossPips: slPips,
            takeProfitPips: tpPips,
            riskRewardRatio: rr,
            breakeven: entry.toFixed(precision)
        };

        displayResults(result, direction);
    });

    function displayResults(data, direction) {
        const resultsDiv = document.getElementById('results');
        resultsDiv.classList.add('show');
        
        // Aktualizacja UI
        document.getElementById('stopLoss').textContent = data.stopLoss;
        document.getElementById('takeProfit').textContent = data.takeProfit;
        document.getElementById('slPips').textContent = data.stopLossPips + ' pips from entry';
        document.getElementById('tpPips').textContent = data.takeProfitPips + ' pips from entry';
        document.getElementById('rrRatio').textContent = '1:' + data.riskRewardRatio;
        document.getElementById('breakeven').textContent = data.breakeven;
        
        // Dynamiczna zmiana kolorów dla wizualizacji
        const slBox = document.getElementById('slDisplay');
        const tpBox = document.getElementById('tpDisplay');
        
        // SL zawsze na czerwono (ryzyko), TP na zielono (zysk)
        slBox.className = 'alert alert-danger'; // Zmiana na czerwony
        tpBox.className = 'alert alert-success'; // Zostaje zielony

        const ratio = parseFloat(data.riskRewardRatio);
        let recHTML = '';
        
        if (ratio >= 3) {
            recHTML = '<div class="alert alert-success">✓ EXCELLENT R:R RATIO – Very strong trade setup!</div>';
        } else if (ratio >= 2) {
            recHTML = '<div class="alert alert-success">✓ VERY GOOD R:R RATIO – Solid trade.</div>';
        } else if (ratio >= 1.5) {
            recHTML = '<div class="alert alert-warning">⚠ AVERAGE R:R RATIO – Consider increasing TP.</div>';
        } else {
            recHTML = '<div class="alert alert-danger">✗ POOR R:R RATIO – Trade not recommended.</div>';
        }
        
        document.getElementById('recommendation').innerHTML = recHTML;
        resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function resetForm() {
        form.reset();
        document.getElementById('results').classList.remove('show');
    }
</script>
</body>
</html>
